# Optional: override default model
OPENAI_MODEL=gpt-4o-mini

# CORS — frontend dev server origin
FRONTEND_ORIGIN=http://localhost:5173

# Paths
DATA_DIR=../data
CORPUS_DIR=../data/corpus
SOURCES_DIR=../data/sources
